{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["findings", "summary"],
  "properties": {
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["file", "line", "severity", "issue", "suggestion"],
        "properties": {
          "file": { "type": "string" },
          "line": { "type": "integer" },
          "severity": {
            "type": "string",
            "enum": ["critical", "warning", "suggestion"]
          },
          "issue": { "type": "string" },
          "suggestion": { "type": "string" }
        }
      }
    },
    "summary": { "type": "string" }
  }
}
